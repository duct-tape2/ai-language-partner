      "path": "audio/haruka_weather_seasons_n4_a04.wav",
      "category": "dialogue",
      "text": "注意を伝えます。 ゆっくり正確に確認しましょう。",
      "voiceUsed": "aivis_まお_ふつー_2",
      "engine": "aivis_speech"
    },
    {
      "lineId": "haruka_weather_seasons_n4_a05",
      "path": "audio/haruka_weather_seasons_n4_a05.wav",
      "category": "dialogue",
      "text": "相手の地域を聞きます。 ゆっくり正確に確認しましょう。",
      "voiceUsed": "aivis_まお_ふつー_2",
      "engine": "aivis_speech"
    },
    {
      "lineId": "haruka_weather_seasons_n4_a06",
      "path": "audio/haruka_weather_seasons_n4_a06.wav",
      "category": "dialogue",
      "text": "自然な感想で締めます。 ゆっくり正確に確認しましょう。",
      "voiceUsed": "aivis_まお_ふつー_2",
      "engine": "aivis_speech"
    },
    {
      "lineId": "haruka_filler_001",
      "text": "はい、確認します。",
      "path": "audio/haruka_filler_001.wav",
      "category": "filler",
      "voiceUsed": "aivis_まお_あまあま_3",
      "engine": "aivis_speech"
    },
    {
      "lineId": "haruka_filler_002",
      "text": "発音は落ち着いています。",
      "path": "audio/haruka_filler_002.wav",
      "category": "filler",
      "voiceUsed": "aivis_まお_あまあま_3",
      "engine": "aivis_speech"
    },
    {
      "lineId": "haruka_filler_003",
      "text": "文の形はいいです。",
      "path": "audio/haruka_filler_003.wav",
      "category": "filler",
      "voiceUsed": "aivis_まお_あまあま_3",
      "engine": "aivis_speech"
    },
    {
      "lineId": "haruka_filler_004",
      "text": "少し待ってください。",
      "path": "audio/haruka_filler_004.wav",
      "category": "filler",
      "voiceUsed": "aivis_まお_あまあま_3",
      "engine": "aivis_speech"
    },
    {
      "lineId": "haruka_filler_005",
      "text": "聞き取れています。",
      "path": "audio/haruka_filler_005.wav",
      "category": "filler",
      "voiceUsed": "aivis_まお_あまあま_3",
      "engine": "aivis_speech"
    },
    {
      "lineId": "haruka_confirm_001",
      "text": "今の意図はこちらで合っていますか。",
      "path": "audio/haruka_confirm_001.wav",
      "category": "confirm",
      "voiceUsed": "aivis_コハク_ノーマル_7",
      "engine": "aivis_speech"
    },
    {
      "lineId": "haruka_confirm_002",
      "text": "もう一度、同じ内容で言えますか。",
      "path": "audio/haruka_confirm_002.wav",
      "category": "confirm",
      "voiceUsed": "aivis_コハク_ノーマル_7",
      "engine": "aivis_speech"
    },
    {
      "lineId": "haruka_confirm_003",
      "text": "この選択肢に近いでしょうか。",
      "path": "audio/haruka_confirm_003.wav",
      "category": "confirm",
      "voiceUsed": "aivis_コハク_ノーマル_7",
      "engine": "aivis_speech"
    },
    {
      "lineId": "haruka_confirm_004",
      "text": "意味は近いので確認します。",
      "path": "audio/haruka_confirm_004.wav",
      "category": "confirm",
      "voiceUsed": "aivis_コハク_ノーマル_7",
      "engine": "aivis_speech"
    },
    {
      "lineId": "haruka_confirm_005",
      "text": "どの表現を使いたいですか。",
      "path": "audio/haruka_confirm_005.wav",
      "category": "confirm",
      "voiceUsed": "aivis_コハク_ノーマル_7",
      "engine": "aivis_speech"
    },
    {
      "lineId": "haruka_fallback_001",
      "text": "すみません、現在の場面では判断できませんでした。",
      "path": "audio/haruka_fallback_001.wav",
      "category": "fallback",
      "voiceUsed": "aivis_コハク_あまあま_8",
      "engine": "aivis_speech"
    },
    {
      "lineId": "haruka_fallback_002",
      "text": "候補文に近い形で言い直しましょう。",
      "path": "audio/haruka_fallback_002.wav",
      "category": "fallback",
      "voiceUsed": "aivis_コハク_あまあま_8",
      "engine": "aivis_speech"
    },
    {
      "lineId": "haruka_fallback_003",
      "text": "短い文にしてもう一度お願いします。",
      "path": "audio/haruka_fallback_003.wav",
      "category": "fallback",
      "voiceUsed": "aivis_コハク_あまあま_8",
      "engine": "aivis_speech"
    },
    {
      "lineId": "haruka_fallback_004",
      "text": "ゆっくり発話してください。",
      "path": "audio/haruka_fallback_004.wav",
      "category": "fallback",
      "voiceUsed": "aivis_コハク_あまあま_8",
      "engine": "aivis_speech"
    },
    {
      "lineId": "haruka_fallback_005",
      "text": "この練習では場面内の表現に戻ります。",
      "path": "audio/haruka_fallback_005.wav",
      "category": "fallback",
      "voiceUsed": "aivis_コハク_あまあま_8",
      "engine": "aivis_speech"
    }
  ],
