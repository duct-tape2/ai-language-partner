      "lineId": "yui_filler_002",
      "text": "その調子だよ。",
      "path": "audio/yui_filler_002.wav",
      "category": "filler",
      "voiceUsed": "aivis_まお_ふつー_2",
      "engine": "aivis_speech"
    },
    {
      "lineId": "yui_filler_003",
      "text": "今の自然だった。",
      "path": "audio/yui_filler_003.wav",
      "category": "filler",
      "voiceUsed": "aivis_まお_ふつー_2",
      "engine": "aivis_speech"
    },
    {
      "lineId": "yui_filler_004",
      "text": "ちょっと待ってね。",
      "path": "audio/yui_filler_004.wav",
      "category": "filler",
      "voiceUsed": "aivis_まお_ふつー_2",
      "engine": "aivis_speech"
    },
    {
      "lineId": "yui_filler_005",
      "text": "聞こえてるよ。",
      "path": "audio/yui_filler_005.wav",
      "category": "filler",
      "voiceUsed": "aivis_まお_ふつー_2",
      "engine": "aivis_speech"
    },
    {
      "lineId": "yui_confirm_001",
      "text": "今のはこういう意味で合ってる？",
      "path": "audio/yui_confirm_001.wav",
      "category": "confirm",
      "voiceUsed": "aivis_まお_せつなめ_6",
      "engine": "aivis_speech"
    },
    {
      "lineId": "yui_confirm_002",
      "text": "もう一回だけ言ってみる？",
      "path": "audio/yui_confirm_002.wav",
      "category": "confirm",
      "voiceUsed": "aivis_まお_せつなめ_6",
      "engine": "aivis_speech"
    },
    {
      "lineId": "yui_confirm_003",
      "text": "この表現を選ぶ感じでいい？",
      "path": "audio/yui_confirm_003.wav",
      "category": "confirm",
      "voiceUsed": "aivis_まお_せつなめ_6",
      "engine": "aivis_speech"
    },
    {
      "lineId": "yui_confirm_004",
      "text": "近いよ、少し確認しよう。",
      "path": "audio/yui_confirm_004.wav",
      "category": "confirm",
      "voiceUsed": "aivis_まお_せつなめ_6",
      "engine": "aivis_speech"
    },
    {
      "lineId": "yui_confirm_005",
      "text": "どっちの意味か教えて。",
      "path": "audio/yui_confirm_005.wav",
      "category": "confirm",
      "voiceUsed": "aivis_まお_せつなめ_6",
      "engine": "aivis_speech"
    },
    {
      "lineId": "yui_fallback_001",
      "text": "ごめん、今の言い方は拾えなかった。",
      "path": "audio/yui_fallback_001.wav",
      "category": "fallback",
      "voiceUsed": "aivis_コハク_ノーマル_7",
      "engine": "aivis_speech"
    },
    {
      "lineId": "yui_fallback_002",
      "text": "候補から近いものを選んでみて。",
      "path": "audio/yui_fallback_002.wav",
      "category": "fallback",
      "voiceUsed": "aivis_コハク_ノーマル_7",
      "engine": "aivis_speech"
    },
    {
      "lineId": "yui_fallback_003",
      "text": "短く言い直してくれる？",
      "path": "audio/yui_fallback_003.wav",
      "category": "fallback",
      "voiceUsed": "aivis_コハク_ノーマル_7",
      "engine": "aivis_speech"
    },
    {
      "lineId": "yui_fallback_004",
      "text": "もう少しゆっくりお願い。",
      "path": "audio/yui_fallback_004.wav",
      "category": "fallback",
      "voiceUsed": "aivis_コハク_ノーマル_7",
      "engine": "aivis_speech"
    },
    {
      "lineId": "yui_fallback_005",
      "text": "今はこの場面の表現で練習しよう。",
      "path": "audio/yui_fallback_005.wav",
      "category": "fallback",
      "voiceUsed": "aivis_コハク_ノーマル_7",
      "engine": "aivis_speech"
    }
