    {
      "lineId": "ren_filler_001",
      "text": "お、いいね。",
      "path": "audio/ren_filler_001.wav",
      "category": "filler",
      "voiceUsed": "voicevox_zundamon_normal"
    },
    {
      "lineId": "ren_filler_002",
      "text": "今のノリ悪くない。",
      "path": "audio/ren_filler_002.wav",
      "category": "filler",
      "voiceUsed": "voicevox_zundamon_normal"
    },
    {
      "lineId": "ren_filler_003",
      "text": "そのまま行こう。",
      "path": "audio/ren_filler_003.wav",
      "category": "filler",
      "voiceUsed": "voicevox_zundamon_normal"
    },
    {
      "lineId": "ren_filler_004",
      "text": "ちょい待ち。",
      "path": "audio/ren_filler_004.wav",
      "category": "filler",
      "voiceUsed": "voicevox_zundamon_normal"
    },
    {
      "lineId": "ren_filler_005",
      "text": "聞こえてるぞ。",
      "path": "audio/ren_filler_005.wav",
      "category": "filler",
      "voiceUsed": "voicevox_zundamon_normal"
    },
    {
      "lineId": "ren_confirm_001",
      "text": "今の、こっちの意味で合ってる？",
      "path": "audio/ren_confirm_001.wav",
      "category": "confirm",
      "voiceUsed": "voicevox_zundamon_whisper"
    },
    {
      "lineId": "ren_confirm_002",
      "text": "もう一回いっとく？",
      "path": "audio/ren_confirm_002.wav",
      "category": "confirm",
      "voiceUsed": "voicevox_zundamon_whisper"
    },
    {
      "lineId": "ren_confirm_003",
      "text": "この返事を狙った感じ？",
      "path": "audio/ren_confirm_003.wav",
      "category": "confirm",
      "voiceUsed": "voicevox_zundamon_whisper"
    },
    {
      "lineId": "ren_confirm_004",
      "text": "近いから確認な。",
      "path": "audio/ren_confirm_004.wav",
      "category": "confirm",
      "voiceUsed": "voicevox_zundamon_whisper"
    },
    {
      "lineId": "ren_confirm_005",
      "text": "どっちで返したい？",
      "path": "audio/ren_confirm_005.wav",
      "category": "confirm",
      "voiceUsed": "voicevox_zundamon_whisper"
    },
    {
      "lineId": "ren_fallback_001",
      "text": "悪い、今のは拾えなかった。",
      "path": "audio/ren_fallback_001.wav",
      "category": "fallback",
      "voiceUsed": "voicevox_zundamon_normal"
    },
    {
      "lineId": "ren_fallback_002",
      "text": "候補に寄せてもう一回。",
      "path": "audio/ren_fallback_002.wav",
      "category": "fallback",
      "voiceUsed": "voicevox_zundamon_normal"
    },
    {
      "lineId": "ren_fallback_003",
      "text": "短く言い直してみ。",
      "path": "audio/ren_fallback_003.wav",
      "category": "fallback",
      "voiceUsed": "voicevox_zundamon_normal"
    },
    {
      "lineId": "ren_fallback_004",
      "text": "もう少しゆっくり頼む。",
      "path": "audio/ren_fallback_004.wav",
      "category": "fallback",
      "voiceUsed": "voicevox_zundamon_normal"
    },
    {
      "lineId": "ren_fallback_005",
      "text": "いったんこの場面のセリフに戻ろう。",
      "path": "audio/ren_fallback_005.wav",
      "category": "fallback",
      "voiceUsed": "voicevox_zundamon_normal"
    }
