{
  "name": "AI Language Partner",
  "image": "mcr.microsoft.com/devcontainers/python:1-3.11-bookworm",
  "features": {
    "ghcr.io/devcontainers/features/node:1": {
      "version": "20"
    }
  },
  "postCreateCommand": "python -m venv apps/api/.venv && apps/api/.venv/bin/python -m pip install --upgrade pip && apps/api/.venv/bin/pip install -r apps/api/requirements.txt && cd apps/mobile && npm ci",
  "forwardPorts": [
    8001,
    19006,
    8081
  ],
  "portsAttributes": {
    "8001": {
      "label": "FastAPI dev server",
      "onAutoForward": "notify"
    },
    "19006": {
      "label": "Expo web",
      "onAutoForward": "notify"
    },
    "8081": {
      "label": "Metro bundler",
      "onAutoForward": "silent"
    }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "dbaeumer.vscode-eslint"
      ],
      "settings": {
        "python.defaultInterpreterPath": "${workspaceFolder}/apps/api/.venv/bin/python",
        "terminal.integrated.defaultProfile.linux": "bash"
      }
    }
  }
}
