{
  "name": "ai-language-partner-mobile",
  "version": "0.1.0",
  "private": true,
  "main": "index.js",
  "scripts": {
    "start": "expo start",
    "ios": "expo start --ios",
    "android": "expo start --android",
    "web": "expo start --web",
    "verify": "npm run typecheck && npm run verify:frontend-regressions && npm run verify:readme-scripts",
    "typecheck": "tsc --noEmit",
    "verify:frontend-regressions": "node scripts/verify-frontend-regressions.mjs",
    "verify:prod-no-secret": "node scripts/verify-prod-no-attestation-secret.mjs",
    "verify:readme-scripts": "node scripts/verify-readme-scripts.mjs && node scripts/test-verify-readme-scripts.mjs"
  },
  "dependencies": {
    "@expo/metro-runtime": "~4.0.1",
    "@react-native-async-storage/async-storage": "1.23.1",
    "expo": "~52.0.47",
    "expo-asset": "~11.0.5",
    "expo-av": "~15.0.2",
    "expo-file-system": "~18.0.12",
    "expo-haptics": "~14.0.1",
    "expo-speech": "~13.0.1",
    "expo-status-bar": "~2.0.1",
    "fflate": "^0.8.3",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-native": "0.76.9",
    "react-native-safe-area-context": "4.12.0",
    "react-native-svg": "15.8.0",
    "react-native-web": "~0.19.13",
    "ts-fsrs": "^5.4.1"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@types/react": "~18.3.12",
    "typescript": "^5.3.3"
  }
}
